VIDEO_PIPELINE_APP_NAME=Video Automation Studio
NEXT_PUBLIC_APP_URL=http://localhost:3000

# ── PostgreSQL ──────────────────────────────────
# Local:  postgresql://postgres:postgres@127.0.0.1:5432/video_automation
# Neon:   postgresql://user:pass@ep-xxxx.us-east-2.aws.neon.tech/video_automation?sslmode=require
DATABASE_URL=postgresql://postgres:postgres@127.0.0.1:5432/video_automation
# Set to "1" when connecting to cloud Postgres that enforces SSL (Neon, Supabase, etc.)
# DATABASE_SSL=0

# ── Redis ───────────────────────────────────────
# Local:    redis://127.0.0.1:6379
# Upstash:  rediss://default:password@us1-dashing-mastiff-12345.upstash.io:6379
REDIS_URL=redis://127.0.0.1:6379

# ── Object Storage (future) ─────────────────────
OBJECT_STORAGE_BUCKET=video-automation-dev
OBJECT_STORAGE_REGION=local
OBJECT_STORAGE_ENDPOINT=http://localhost:9000
OBJECT_STORAGE_ACCESS_KEY=minioadmin
OBJECT_STORAGE_SECRET_KEY=minioadmin

# ── AI Providers ────────────────────────────────
ASR_PROVIDER=local-fallback
ASR_API_KEY=
ASR_BASE_URL=
ASR_MODEL=whisper-1

TRANSLATION_PROVIDER=local-fallback
TRANSLATION_API_KEY=
TRANSLATION_BASE_URL=
TRANSLATION_MODEL=gpt-4o-mini

TTS_PROVIDER=local-fallback
TTS_API_KEY=
TTS_BASE_URL=
TTS_MODEL=gpt-4o-mini-tts
TTS_VOICE=alloy

# ── Media Tools ─────────────────────────────────
FFMPEG_BINARY=ffmpeg
FFPROBE_BINARY=ffprobe

# ── Worker ──────────────────────────────────────
WORKER_MAX_ATTEMPTS=3
WORKER_RETRY_DELAY_MS=5000
WORKER_CONCURRENCY=1
